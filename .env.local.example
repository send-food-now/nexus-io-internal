# ============================================
# Local Development Environment Variables
# Copy to .env.local and fill in your keys
# ============================================

# --- REQUIRED for pipeline to run ---

# Claude API (Stages 1 & 5: profiling + outreach generation)
ANTHROPIC_API_KEY=

# Google Sheets / Drive service account (Stage 6: spreadsheet export)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Resend email API (Stage 7: admin notification)
RESEND_API_KEY=

# Admin email — receives pipeline completion notifications
ADMIN_EMAIL=

# Frontend password gate
NEXT_PUBLIC_ADMIN_PASSWORD=admin

# --- OPTIONAL ---

# Serper web search API (Stages 2 & 4: startup discovery + news)
# Pipeline works without this — mock data still flows through
SERPER_API_KEY=

# --- NOT NEEDED for local dev ---

# Inngest keys — not required when using `npx inngest-cli@latest dev`
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# Vercel KV — falls back to in-memory store when unset
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
